{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Apiome custom lint rules",
  "description": "Spectral-compatible subset (GOV-1.3): rules.<id> with description, severity, given, then.",
  "type": "object",
  "required": ["rules"],
  "additionalProperties": false,
  "properties": {
    "rules": {
      "type": "object",
      "additionalProperties": { "$ref": "#/definitions/rule" }
    }
  },
  "definitions": {
    "rule": {
      "type": "object",
      "required": ["description", "given", "then"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "given": {
          "oneOf": [
            { "type": "string", "minLength": 1 },
            { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } }
          ]
        },
        "then": {
          "oneOf": [
            { "$ref": "#/definitions/thenClause" },
            {
              "type": "array",
              "minItems": 1,
              "items": { "$ref": "#/definitions/thenClause" }
            }
          ]
        }
      }
    },
    "thenClause": {
      "type": "object",
      "required": ["function"],
      "additionalProperties": false,
      "properties": {
        "field": { "type": "string" },
        "function": {
          "type": "string",
          "enum": [
            "pattern",
            "casing",
            "enumeration",
            "truthy",
            "defined",
            "undefined",
            "length"
          ]
        },
        "functionOptions": { "type": "object" }
      }
    }
  }
}
