# Docker Environment Variables Template
# Copy this file to .env and update the values

# REST API Base URL (must start with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_REST_API_BASE_URL=http://localhost:8000/v1

# Public base URL of the apiome-mock server (no trailing slash). Must match apiome-rest.
# APIOME_MOCK_PUBLIC_BASE_URL=http://localhost:8775

# Public API browser (apiome-browse)
NEXT_PUBLIC_BROWSE_URL=https://browse.apiome.app

# Commercial studio (Data Designer, API Paths)
NEXT_PUBLIC_STUDIO_URL=https://studio.apiome.app

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-secure-random-string

# Sign-in providers (provider registry, OLO-2.3): a provider is enabled only when all of
# its env vars are set and non-blank; unset ones disappear from the login page, the
# linked-accounts panel, and the NextAuth routes. See lib/auth/provider-registry.ts.
# Setup guides + env matrix: docs/AUTH_PROVIDER_SETUP.md. A partially configured provider
# fails startup (OLO-7.2); set AUTH_PROVIDER_VALIDATION=warn to log and disable instead.

# GitHub OAuth (Optional - for GitHub authentication)
GITHUB_ID=your-github-client-id
GITHUB_SECRET=your-github-client-secret
GITHUB_TOKEN=your-github-personal-access-token

# GitLab OAuth (Optional - for GitLab authentication)
# GITLAB_CLIENT_ID=your-gitlab-application-id
# GITLAB_CLIENT_SECRET=your-gitlab-application-secret

# Microsoft Entra ID OAuth (Optional - for Azure authentication, OLO-2.1)
# Redirect URI: {NEXTAUTH_URL}/api/auth/callback/azure — see docs/ENTRA_ID_APP_REGISTRATION.md
# AZURE_AD_CLIENT_ID=your-entra-application-client-id
# AZURE_AD_CLIENT_SECRET=your-entra-client-secret
# AZURE_AD_TENANT=common

# Beta Mode - Set to any value to enable beta indicator
NEXT_PUBLIC_BETA_MODE=true

# Admin Password for super admin site
ADMIN_PASSWORD=change-this-to-a-secure-password

# PostgreSQL Database Configuration
PGHOST=localhost
PGPORT=5432
PGDATABASE=apiome
PGUSER=postgres
PGPASSWORD=change-this-to-a-secure-database-password

# Additional Configuration
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

