# REST API Base URL (must start with NEXT_PUBLIC_ for client-side access)
NEXT_PUBLIC_REST_API_BASE_URL=http://localhost:8000/v1

# Public base URL of the apiome-mock server (no trailing slash). The published-versions
# dashboard composes mock URLs as {APIOME_MOCK_PUBLIC_BASE_URL}/{tenant}/{project}/{version}.
# Set to the URL the mock is reached at from the user's browser/terminal. Read server-side
# at request time (not NEXT_PUBLIC_*); must match apiome-rest's APIOME_MOCK_PUBLIC_BASE_URL.
# APIOME_MOCK_PUBLIC_BASE_URL=http://localhost:8775

# PostgreSQL — use the same database as apiome-rest (see apiome-rest/.env DATABASE_URL)
# This is used for super admin direct access to the database; otherwise, it will use the DATABASE_URL environment variable, which may not be correct.
# DATABASE_URL=postgresql://postgres:password@localhost:5432/apiome

# Public API browser (apiome-browse) — linked from the ADE home tile
NEXT_PUBLIC_BROWSE_URL=https://browse.apiome.app

# Commercial studio (Data Designer, API Paths) — linked from ADE home and top nav
# Defaults to https://studio.apiome.app when unset
NEXT_PUBLIC_STUDIO_URL=https://studio.apiome.app

# Main Apiome app URL — used when the studio surface links back to ADE
# NEXT_PUBLIC_MAIN_APP_URL=https://app.apiome.app

# Set on the standalone studio deployment so nav knows it is the studio surface
# NEXT_PUBLIC_APP_SURFACE=studio

NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=[openssl rand -base64 32]

# ── Sign-in providers (provider registry, OLO-2.3) ─────────────────────────────
# A provider is enabled only when ALL of its env vars below are set and non-blank.
# Enabling/disabling a provider here adds/removes it everywhere at once: the login
# page button, the linked-accounts panel, and its NextAuth sign-in route.
# Registry source: lib/auth/provider-registry.ts
# Setup guides (per-provider app registration + full env matrix): docs/AUTH_PROVIDER_SETUP.md
#
# Boot-time validation (OLO-7.2): a PARTIALLY configured provider (some but not all of
# its vars set) fails server startup with an actionable error. Set to `warn` to log the
# problem instead and leave that provider cleanly disabled. Default: strict.
# AUTH_PROVIDER_VALIDATION=strict

# GitHub sign-in (Optional). OAuth app callback: {NEXTAUTH_URL}/api/auth/callback/github
# GITHUB_ID=your-github-oauth-client-id
# GITHUB_SECRET=your-github-oauth-client-secret

# GitLab sign-in (Optional). Application redirect: {NEXTAUTH_URL}/api/auth/callback/gitlab
# GITLAB_CLIENT_ID=your-gitlab-application-id
# GITLAB_CLIENT_SECRET=your-gitlab-application-secret

# Microsoft Entra ID sign-in (Optional, OLO-2.1). Create an app registration with redirect URI
# {NEXTAUTH_URL}/api/auth/callback/azure and enable the xms_edov optional claim
# (see docs/ENTRA_ID_APP_REGISTRATION.md). Tenant defaults to `common` (multi-tenant);
# set a tenant id/domain to restrict sign-in to one directory.
# AZURE_AD_CLIENT_ID=your-entra-application-client-id
# AZURE_AD_CLIENT_SECRET=your-entra-client-secret
# AZURE_AD_TENANT=common

# Dev only: comma-separated hosts allowed to load Next.js HMR when opening the UI from
# a LAN IP or custom hostname (not localhost). Restart `npm run dev` after changing.
# NEXT_ALLOWED_DEV_ORIGINS=10.0.0.96

# Parent domain for session cookies shared with subdomain apps (studio etc.).
# Set to the deployment's parent domain, e.g. `.apiome.dev`.
# When unset in production, inferred from NEXTAUTH_URL / NEXT_PUBLIC_* app URLs.
# Ignored outside NODE_ENV=production (localhost uses host-only cookies).
# NEXTAUTH_COOKIE_DOMAIN=.apiome.app

# Beta Mode - Set to any value to enable beta indicator on login screen
NEXT_PUBLIC_BETA_MODE=true

# Optional: override ADE header version badge at build time (e.g. 2026.05.05-84a231c). Omit to show v{package.json version}.
# NEXT_PUBLIC_APP_BUILD_LABEL=

# Admin password for super admin site
ADMIN_PASSWORD=your_secure_admin_password_here

# Ollama LLM Server URL for AI-powered import feature
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

