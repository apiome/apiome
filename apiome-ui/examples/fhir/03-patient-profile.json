{
  "_comment": "FHIR R4 example — a Patient StructureDefinition profile with snapshot elements.",
  "resourceType": "StructureDefinition",
  "id": "SimplePatient",
  "url": "http://example.com/fhir/StructureDefinition/SimplePatient",
  "name": "SimplePatient",
  "status": "draft",
  "kind": "resource",
  "abstract": false,
  "type": "Patient",
  "baseDefinition": "http://hl7.org/fhir/StructureDefinition/Patient",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "Patient.identifier",
        "path": "Patient.identifier",
        "min": 0,
        "max": "*",
        "type": [{ "code": "Identifier" }],
        "short": "An identifier for this patient"
      },
      {
        "id": "Patient.active",
        "path": "Patient.active",
        "min": 0,
        "max": "1",
        "type": [{ "code": "boolean" }],
        "short": "Whether this patient record is in active use"
      },
      {
        "id": "Patient.name",
        "path": "Patient.name",
        "min": 0,
        "max": "*",
        "type": [{ "code": "HumanName" }],
        "short": "A name associated with the patient"
      },
      {
        "id": "Patient.gender",
        "path": "Patient.gender",
        "min": 0,
        "max": "1",
        "type": [{ "code": "code" }],
        "short": "male | female | other | unknown"
      }
    ]
  }
