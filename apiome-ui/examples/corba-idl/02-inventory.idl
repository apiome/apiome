// CORBA IDL (OMG IDL) example — inventory lookup service.
//
// Demonstrates sequence typedefs, exceptions, and interface operations with
// raises clauses outside the banking domain.

module Inventory {

  typedef sequence<string> StringList;

  struct Item {
    string sku;
    long quantity;
    StringList tags;
  };

  exception ItemNotFound {
    string sku;
  };

  interface Stock {
    Item lookup(in string sku) raises (ItemNotFound);
    long count(in string sku);
  };
};
