# Production environment template for the Apiome spine.
#
# Copy to `.env` in the repo root (NEXT TO docker-compose.yml) on the deploy host and fill in every
# value below. Unlike docker-compose.env.example (local/dev), there are NO safe defaults here: the
# production overlay (docker-compose.prod.yml) fails closed if a required secret or hostname is
# missing. Generate the secrets with the commands shown — never reuse the dev values.
#
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml config   # validate before deploy
#
# See docs/runbooks/PRODUCTION_DEPLOY.md for the full deploy/rollback procedure.
#
# This file is a TEMPLATE and is safe to commit. The real `.env` MUST NOT be committed (it is
# git-ignored) — it holds live secrets.

# ─────────────────────────── Public hostnames / TLS ───────────────────────────
# DNS A/AAAA records for these names must point at this host before first boot, so Caddy can
# complete the Let's Encrypt ACME challenge over ports 80/443.
DEPLOY_API_DOMAIN=api.example.com
DEPLOY_MCP_DOMAIN=mcp.example.com
DEPLOY_MOCK_DOMAIN=mock.example.com
DEPLOY_STUDIO_DOMAIN=studio.example.com
DEPLOY_APP_DOMAIN=app.example.com
# Contact address Let's Encrypt uses for certificate-expiry notices.
ACME_EMAIL=ops@example.com

# ─────────────────────────────── Postgres ───────────────────────────────
# Strong DB password — generate with: openssl rand -base64 24
POSTGRES_PASSWORD=
# Optional (defaults shown). Keep in sync if you change them.
# POSTGRES_USER=postgres
# POSTGRES_DB=apiome

# ───────────────────────── Application secrets ──────────────────────────
# Shared session/JWT secret (HS256). Signs the Better Auth UI session and the downstream REST JWT
# (apiome-rest must be given the SAME value). Keeps its historical NEXTAUTH_ name. Better Auth
# (OLO-10.3) reuses this secret by default; set BETTER_AUTH_SECRET to migrate onto a dedicated one, or
# BETTER_AUTH_SECRETS ("2:new,1:old") for a non-destructive rotation that logs nobody out (sessions are
# DB-backed). See docs/BETTER_AUTH_MIGRATION.md §1.
#   openssl rand -base64 32
NEXTAUTH_SECRET=
# Parent domain for session cookies shared between the main app and the studio.
# MUST match the parent of DEPLOY_APP_DOMAIN / DEPLOY_STUDIO_DOMAIN (leading dot),
# e.g. `.example.com` — a stale value like `.apiome.app` on an `apiome.dev` deploy
# is ignored by browsers and breaks studio login entirely.
# Scopes the Better Auth session cookie (OLO-10.3), so cross-subdomain sessions are shared.
NEXTAUTH_COOKIE_DOMAIN=.example.com
# Public URL of the studio app. Baked into the Next.js bundle at image build time for
# both the main app and studio services — changing DEPLOY_STUDIO_DOMAIN requires
# rebuilding those images (`docker compose build --no-cache studio` and the main UI).
# MCP internal secret (min 16 chars). openssl rand -base64 24
APIOME_MCP_INTERNAL_SECRET=
# Browser origins allowed to call the REST API (comma-separated). Include main app + studio.
APIOME_CORS_ALLOWED_ORIGINS=https://app.example.com,https://studio.example.com
# Optional: regex for *.apiome.app subdomains (defaults to https://.*\.apiome\.app when unset)
# APIOME_CORS_ALLOWED_ORIGIN_REGEX=https://.*\.apiome\.app
# MCP credential encryption-at-rest (MCAT-6.2, #3678). Consumed by the apiome-rest service.
# REQUIRED before any protected (authenticated) MCP server credential can be stored — without it
# the API fails closed with "MCP credential encryption is not configured; set
# APIOME_MCP_CREDENTIAL_ENCRYPTION_KEYS before storing a secret". JSON object mapping an
# integer key-version to a base64-encoded 32-byte AES-256 master key. Generate ONCE and store in
# your secret manager:  python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# Prefer quotes so accidental `source` of this file in bash does not expand `{…}`:
APIOME_MCP_CREDENTIAL_ENCRYPTION_KEYS='{"1": "<base64 32-byte key>"}'
# Which key-version new secrets are sealed under. Optional; defaults to the highest version present.
# APIOME_MCP_CREDENTIAL_ACTIVE_KEY_VERSION=1

# ────────────────────────── Backups (RC1-1.3) ───────────────────────────
# 32-byte AES-256 key for encrypted backups. Generate ONCE and store in your secret manager,
# NOT on the backup host:  openssl rand -hex 32
# Required by the `backup` service; the scheduled wrapper refuses to run (and never writes
# plaintext) if it is unset.
APIOME_BACKUP_KEY=
# Retention guards (a backup is pruned only when older than KEEP_DAYS *and* not in the KEEP_LAST most recent).
# APIOME_BACKUP_KEEP_DAYS=30
# APIOME_BACKUP_KEEP_LAST=7
