# Copy to `.env` in the repo root (same directory as docker-compose.yml) to override defaults.

# Postgres (must match across postgres / migrate / mcp)
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=apiome_local_dev
# POSTGRES_DB=apiome

# Host port mapping (optional)
# POSTGRES_PUBLISH_PORT=5432

# REST HTTP port on the host (apiome-rest always listens on 8000 in-container)
# APIOME_REST_HTTP_PORT=8000

# MCP HTTP port on the host (must match in-container APIOME_MCP_HTTP_PORT)
# APIOME_MCP_HTTP_PORT=8765

# Required by apiome-mcp at runtime (min 16 characters); compose supplies a dev default
# APIOME_MCP_INTERNAL_SECRET=replace-with-at-least-16-chars

# apiome-rest auth/CORS hardening (see docs/security/AUTH_MODEL.md).
# The Postgres credentials above are DEV-ONLY defaults — override them for any non-local use.
# In production set APIOME_ENV=production AND a strong shared JWT secret, or REST refuses
# to start (it will not fall back to the insecure built-in default).
# APIOME_ENV=development
# NEXTAUTH_SECRET=replace-with-output-of: openssl rand -base64 32
# APIOME_CORS_ALLOWED_ORIGINS=https://app.example.com

# apiome-rest MCP credential encryption-at-rest (MCAT-6.2, #3678). REQUIRED before a
# protected (authenticated) MCP server's credential can be stored — otherwise the API returns
# "MCP credential encryption is not configured; set APIOME_MCP_CREDENTIAL_ENCRYPTION_KEYS
# before storing a secret". JSON mapping an integer key-version to a base64 32-byte AES-256 key.
# Generate: python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# APIOME_MCP_CREDENTIAL_ENCRYPTION_KEYS={"1": "<base64 32-byte key>"}

# Optional apiome-mcp overrides (defaults documented in apiome-mcp/docs/CONFIGURATION.md)
# APIOME_MCP_LOG_LEVEL=INFO
# APIOME_MCP_DATABASE_POOL_MIN_SIZE=1
# APIOME_MCP_DATABASE_POOL_MAX_SIZE=10
# APIOME_MCP_DATABASE_POOL_TIMEOUT=30
# APIOME_MCP_OPENAPI_MAX_JSON_BYTES=2097152
