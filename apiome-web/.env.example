# Primary call-to-action destinations for the marketing site.
# These are inlined at build time — set them before `next build`.
# Defaults (used when unset) are shown below.

# "Launch App" button
NEXT_PUBLIC_APP_URL=https://app.apiome.app

# "Browse APIs" button
NEXT_PUBLIC_BROWSE_URL=https://browse.apiome.app

# "Watch Demo" button
NEXT_PUBLIC_DEMO_URL=https://www.youtube.com/@objectifieddev
