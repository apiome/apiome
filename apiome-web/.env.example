# Primary call-to-action destinations for the marketing site.
# Read at request time on the server — set them in the container / process
# environment (no rebuild required). Bare names take precedence over NEXT_PUBLIC_*.

# "Launch App" button
APP_URL=https://app.apiome.app
# NEXT_PUBLIC_APP_URL=https://app.apiome.app

# "Browse APIs" button
BROWSE_URL=https://browse.apiome.app
# NEXT_PUBLIC_BROWSE_URL=https://browse.apiome.app

# "Watch Demo" button
DEMO_URL=https://www.youtube.com/@objectifieddev
# NEXT_PUBLIC_DEMO_URL=https://www.youtube.com/@objectifieddev
