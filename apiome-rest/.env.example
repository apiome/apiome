# Database configuration
# DATABASE_URL=postgresql://postgres:password@localhost:5432/apiome
#
# Local dev: PostgreSQL must be running and the database must exist before `yarn dev` / uvicorn.
#   psql -U postgres -h localhost -p 5432 -c 'CREATE DATABASE apiome;'
# Then run migrations in order from apiome-db/scripts (see apiome-db/docs/README.md).

# Server configuration
HOST=0.0.0.0
PORT=8000
RELOAD=True

# Deployment environment. Set to "production" for any non-local deployment: this enables
# fail-closed checks (the JWT secret below MUST be set or the service refuses to start).
# APIOME_ENV=development

# JWT Authentication (must match apiome-ui NEXTAUTH_SECRET).
# Generate a strong value, e.g.: openssl rand -base64 32
# Required in production — there is no insecure built-in fallback there.
NEXTAUTH_SECRET=your-nextauth-secret-here

# Shared service token gating the resolved auth-provider read path (OLO-8.5),
# GET /v1/internal/auth-providers/resolved — the one endpoint that returns DECRYPTED
# sign-in provider secrets, for apiome-ui's login-time DB-over-env merge resolver.
# Must MATCH INTERNAL_SERVICE_TOKEN given to apiome-ui. Unset ⇒ the endpoint is
# disabled (503) and providers stay env-configured. Generate: openssl rand -base64 48
# INTERNAL_SERVICE_TOKEN=your-long-random-internal-service-token

# CORS allow-list (optional). Comma-separated exact origins permitted to call the API.
# Defaults to the local Next.js dev ports when unset.
# APIOME_CORS_ALLOWED_ORIGINS=https://app.example.com,https://studio.example.com
# Regex for trusted subdomains (defaults to *.apiome.app). Set empty to disable.
# APIOME_CORS_ALLOWED_ORIGIN_REGEX=https://.*\.apiome\.app

# SSRF guard (#3612). User-supplied URLs (import-from-URL, public repository
# registration) are rejected if they resolve to non-public addresses. Set to
# true ONLY for local development that imports from localhost/private hosts.
# APIOME_SSRF_ALLOW_PRIVATE=false

# Per-tenant rate limiting (#3612). Disable with =false. Authenticated traffic
# (API key / JWT) uses the higher limit; public traffic uses the lower one.
# Limits are per replica (in-process counter).
# APIOME_RATE_LIMIT_ENABLED=true
# APIOME_RATE_LIMIT_AUTHENTICATED_PER_MINUTE=600
# APIOME_RATE_LIMIT_PUBLIC_PER_MINUTE=120
# APIOME_RATE_LIMIT_WINDOW_SECONDS=60

# Observability & error handling (#3617, RC1-3.2). Structured JSON logs, request-id
# propagation, and the ops dashboard.
# APIOME_LOG_LEVEL=INFO            # DEBUG/INFO/WARNING/ERROR/CRITICAL
# APIOME_LOG_JSON=true             # set false for human-friendly console logs in local dev
# APIOME_REQUEST_ID_HEADER=X-Request-ID

# Backup status on the ops dashboard (reads RC1-1.3 backup manifests, #3613). Point this at the
# same directory the backup tooling writes to (APIOME_BACKUP_DIR). When unset, backup status
# is reported as "unconfigured" rather than failing.
# APIOME_BACKUP_DIR=/var/backups/apiome
# APIOME_BACKUP_STALE_AFTER_HOURS=24   # latest backup older than this is flagged "stale"

# MCP credential encryption-at-rest (MCAT-6.2, #3678). Set on the apiome-rest service —
# it is this service that seals/unseals secrets for protected (authenticated) MCP servers.
# REQUIRED before a protected MCP server's credential can be stored: without it the API returns
# "MCP credential encryption is not configured; set APIOME_MCP_CREDENTIAL_ENCRYPTION_KEYS
# before storing a secret". The server still starts when unset — only the storing of MCP secrets
# is blocked (fail-closed); discovery of unauthenticated MCP servers is unaffected.
# Value is a JSON object mapping an integer key-version to a base64-encoded 32-byte AES-256 key.
# Generate a key with:
#   python -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# Quote the JSON when this file is loaded by bash (run.sh). Single quotes are safest:
# APIOME_MCP_CREDENTIAL_ENCRYPTION_KEYS='{"1": "<base64 32-byte key>"}'
# Which key-version new secrets are sealed under. Optional; defaults to the highest version present.
# APIOME_MCP_CREDENTIAL_ACTIVE_KEY_VERSION=1

# Optional: override bundled toolchain binaries (MFI-5.2). Local dev normally uses
# apiome-rest/.tools/bin installed by scripts/install_dev_toolchain.sh via run.sh.
# APIOME_BUF_BIN=/absolute/path/to/buf

# Set these values for use with NextAuth configurations
# AUTH_CONFIG_ENC_KEY - a 32-byte AES-256 KEK used to seal client secrets
# AUTH_CONFIG_ENC_KEY=<openssl rand -base64 32>
# INTERNAL_SERVICE_TOKEN - see above documentation
# INTERNAL_SERVICE_TOKEN=<openssl rand -base64 48>

# Super-admin session verification (OLO-8.4). The /admin portal (apiome-ui) mints an
# HMAC-signed admin_session token; REST re-verifies it before serving the provider-config
# admin surface (GET/PUT /v1/admin/auth-providers), so the signing key must MATCH the UI's.
# Key resolution (identical on both sides): ADMIN_SESSION_SECRET wins; otherwise the key
# is derived from ADMIN_PASSWORD. With neither set, REST fails closed and rejects every
# admin session with 403 — the admin settings screen then shows "session expired" even
# though the operator just logged in.
# Recommended: set the same dedicated ADMIN_SESSION_SECRET here and in apiome-ui/.env.
# Fallback: mirror apiome-ui's ADMIN_PASSWORD here instead.
# ADMIN_SESSION_SECRET=<openssl rand -base64 32, same value as apiome-ui>
# ADMIN_PASSWORD=<same value as ADMIN_PASSWORD in apiome-ui/.env>
