# apiome-db — environment settings
#
# Copy to `.env` and adjust. The CLI reads these from the process environment; values shown
# after `=` are the built-in defaults (commented out so the defaults apply unless you override).

# ── Database connection ───────────────────────────────────────────────────────
# Resolution order (first match wins):
#   1. --database-url flag
#   2. APIOME_DB_URL
#   3. DATABASE_URL
#   4. individual --host/--port/--user/--password/--database flags
#   5. POSTGRES_* below (also used by docker-compose.yml)
# APIOME_DB_URL=postgresql://postgres:apiome_local_dev@localhost:5432/apiome
# DATABASE_URL=postgresql://postgres:apiome_local_dev@localhost:5432/apiome
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=apiome_local_dev
# POSTGRES_DB=apiome

# ── Flyway settings ───────────────────────────────────────────────────────────
# Migrations are Flyway-style versioned scripts (scripts/V<version>__<description>.sql) tracked
# in a Flyway-shaped history table.
#
# Name of the schema-history table.
# FLYWAY_SCHEMA_HISTORY_TABLE=flyway_schema_history
# Schema the history table lives in (kept out of the app `apiome` schema so it survives `clean`).
# FLYWAY_DEFAULT_SCHEMA=public
# Guard for `clean` (drops the apiome schema). Must be set to false (or pass --force) to allow it.
# FLYWAY_CLEAN_DISABLED=true

# ── Seed data (development only) ──────────────────────────────────────────────
# Directory of idempotent *.sql seed files applied by `apiome-db seed`.
# APIOME_DB_SEED_DIR=./seed/dev

# ── Backup & disaster recovery ────────────────────────────────────────────────
# See docs/runbooks/BACKUP_AND_DR.md. Used by `apiome-db backup …` and
# scripts/backup/scheduled-backup.sh.
#
# Primary directory for backup artifacts + manifests.
# APIOME_BACKUP_DIR=./backups
# Off-site mirror directory (artifacts are copied here too). Recommended in production.
# APIOME_BACKUP_OFFSITE_DIR=/mnt/offsite/apiome
# 32-byte AES-256 key as 64-char hex or base64 (generate: `openssl rand -hex 32`).
# Store this in a secrets manager, NOT next to the backups — losing it loses the backups.
# APIOME_BACKUP_KEY=
# Retention guards used by the scheduled-backup wrapper / `backup prune`.
# APIOME_BACKUP_KEEP_DAYS=30
# APIOME_BACKUP_KEEP_LAST=7
