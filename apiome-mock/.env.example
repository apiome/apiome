# apiome-mock environment (prefix APIOME_MOCK_)
# Copy to ".env" in your working directory. Schema matches apiome_mock.settings.Settings.

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------
APIOME_MOCK_DATABASE_URL=postgresql://user:password@localhost:5432/apiome

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# APIOME_MOCK_LOG_LEVEL=INFO
# APIOME_MOCK_HTTP_HOST=127.0.0.1
# APIOME_MOCK_HTTP_PORT=8775
# APIOME_MOCK_DATABASE_POOL_MIN_SIZE=1
# APIOME_MOCK_DATABASE_POOL_MAX_SIZE=10
# APIOME_MOCK_DATABASE_POOL_TIMEOUT=30
# APIOME_MOCK_SPEC_CACHE_MAX_ENTRIES=128
# APIOME_MOCK_SPEC_CACHE_TTL_SECONDS=300
# APIOME_MOCK_SPEC_NOTIFY_CHANNEL=apiome_mock_spec_published
