# Apiome CLI Configuration
# Copy this file to .env and fill in your values, or set environment variables directly.
# The CLI respects the following precedence: CLI flags > environment variables > dotenv files > config file > defaults
# Use --env-file on the command line to load a specific dotenv file instead of the default package/cwd .env files.

# Base URL for the Apiome REST API
# Default: http://localhost:8000
APIOME_BASE_URL=http://localhost:8000

# Tenant ID (UUID format, optional)
# Required for API operations that need tenant scope
APIOME_TENANT_ID=

# API key for authentication (optional)
# Required for API operations that need authentication
APIOME_API_KEY=

# UI session bearer token from POST /auth/login (optional)
# Required for auth and personal-access-token commands
APIOME_SESSION_TOKEN=
